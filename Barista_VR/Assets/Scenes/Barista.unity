  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  teksTutorial: {fileID: 272640050}
  daftarInstruksi:
  - Arahkan laser ke pelanggan dan tekan tombol untuk melayani.
  - Ambil Portafilter dan letakkan di atas timbangan.
  - Ambil sendok, ambil kopi dari toples, dan tuang ke Portafilter (15g).
  - Ambil Tamper dan tekan kopi di Portafilter sampai padat.
  - Pasang Portafilter ke mesin kopi.
  - Taruh gelas di bawah mesin.
  - Sajikan kopi ke piring di depan pelanggan.
  prefabEfekPetunjuk: {fileID: 130578850295889416, guid: b0f7df2666274a342b4831e0dba78106, type: 3}
